import java.util.Scanner;

public class Solution {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int max = 0, count = 0;

        for (int i = 0; i < n; i++) {
            int height = sc.nextInt();
            if (height > max) {
                max = height;
                count = 1; // New tallest candle found, reset count to 1
            } else if (height == max) {
                count++;   // Another candle of the same max height found
            }
        }
        System.out.println(count);
    }
}
